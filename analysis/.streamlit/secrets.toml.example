# 把這個檔案複製成 secrets.toml 並填入真實值。
# secrets.toml 不要 commit 上 git!
#
# 線上 deploy 時:
#     在 Streamlit Cloud 的 Settings → Secrets 直接貼下面的內容,
#     不需要實際建立 secrets.toml 檔。

# Google Sheet 的 CSV 匯出網址
# 取得方法:
#   1. 開啟你的 Sheet
#   2. 「共用」改為「知道連結的人」可檢視
#   3. 把分享網址裡的 /edit?gid=0... 替換成 /export?format=csv
GOOGLE_SHEET_CSV_URL = "https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/export?format=csv"

# Gemini API key(想用 AI 日報才需要,免費申請: https://aistudio.google.com/apikey)
GEMINI_API_KEY = "AIzaSy_YOUR_KEY"
